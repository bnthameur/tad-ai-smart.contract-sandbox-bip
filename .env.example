# TAD AI Smart Contract Security Sandbox
# Environment Variables

# Blockchain RPC URLs
RPC_URL_MAINNET=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_URL_BSC=https://bsc-dataseed.binance.org
RPC_URL_POLYGON=https://polygon-rpc.com

# Blockchain Explorer API Keys
ETHERSCAN_API_KEY=your_etherscan_key
BSCSCAN_API_KEY=your_bscscan_key
POLYGONSCAN_API_KEY=your_polygonscan_key
ARBISCAN_API_KEY=your_arbiscan_key

# AI Model API Keys (Choose your provider)
# DeepSeek ($0.27/M tokens) - Best value
DEEPSEEK_API_KEY=your_deepseek_key

# Qwen ($0.50/M tokens) - Good for coding
QWEN_API_KEY=your_qwen_key

# Kimi ($0.50/M tokens) - Moonshot AI
KIMI_API_KEY=your_kimi_key

# OpenAI ($5.00/M tokens) - GPT-4o
OPENAI_API_KEY=your_openai_key

# Anthropic ($3.00/M tokens) - Claude 3.5
ANTHROPIC_API_KEY=your_anthropic_key

# Google ($0.10/M tokens) - Gemini
GOOGLE_API_KEY=your_google_key

# Local Models (Ollama/vLLM) - FREE
LOCAL_API_KEY=not-needed
LOCAL_LLM_URL=http://localhost:11434/v1/chat/completions
LOCAL_MODEL_NAME=llama3

# Docker settings
COMPOSE_PROJECT_NAME=tad-ai-sandbox

# Logging
LOG_LEVEL=INFO
